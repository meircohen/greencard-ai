{
  "name": "greencard-ai",
  "main": ".open-next/worker.js",
  "compatibility_date": "2026-04-01",
  "compatibility_flags": ["nodejs_compat"],
  "assets": {
    "directory": ".open-next/assets",
    "binding": "ASSETS"
  },
  // Custom domain: greencard.bigcohen.org
  "routes": [
    {
      "pattern": "greencard.bigcohen.org",
      "custom_domain": true
    }
  ]
}
