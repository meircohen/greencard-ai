# =============================================================================
# GreenCard.ai Environment Variables
# Copy to .env.local and fill in your values
# =============================================================================

# --- Required for core features ---

# Anthropic API key (chat, assessment, RFE decoder, form-fill)
ANTHROPIC_API_KEY=sk-ant-...

# Neon PostgreSQL (get from console.neon.tech)
DATABASE_URL=postgresql://user:password@host.neon.tech/greencard?sslmode=require

# JWT auth secret (generate: openssl rand -base64 32)
JWT_SECRET=your-jwt-secret-here

# PII field-level encryption key (generate: openssl rand -base64 32)
PII_ENCRYPTION_KEY=your-32-byte-base64-key

# --- Stripe billing ---
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_PROFESSIONAL=price_...

# --- Optional services ---

# Email (SendGrid or Resend)
SENDGRID_API_KEY=SG...
EMAIL_FROM=noreply@greencard.ai

# OAuth
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Cloudflare R2 (document storage)
R2_ACCESS_KEY_ID=your-r2-access-key
R2_SECRET_ACCESS_KEY=your-r2-secret-key
R2_BUCKET_NAME=greencard-ai-docs

# Twilio (SMS notifications)
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token

# Analytics / APM
SENTRY_DSN=your-sentry-dsn
NEXT_PUBLIC_POSTHOG_KEY=your-posthog-key

# --- App config ---
NEXT_PUBLIC_SITE_URL=https://greencard.ai
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development
LOG_LEVEL=debug

# --- Cloudflare deployment (GitHub Actions) ---
CLOUDFLARE_API_TOKEN=...
CLOUDFLARE_ACCOUNT_ID=5b7ff785c6c9e076c4421683dd946bf2
